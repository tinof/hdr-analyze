{
  "enabledPlugins": {
    "rust-skills@rust-skills": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|mcp__morph-mcp__edit_file",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'cd /home/ubuntu/hdr-analyze && cargo fmt --all -- --check 2>&1 | head -20 || true'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|mcp__morph-mcp__edit_file",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'FILE=\"${TOOL_INPUT_file_path:-${TOOL_INPUT_path:-}}\"; if echo \"$FILE\" | grep -qE \"Cargo\\.lock$|\\.env$|\\.mkv$|\\.mp4$|\\.bin$\"; then echo \"BLOCK: Protected file type\"; exit 2; fi'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(cargo fmt:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo test:*)",
      "Bash(cargo build:*)",
      "Bash(cargo run:*)",
      "Bash(ls:*)",
      "Bash(cat /home/ubuntu/hdr-analyze:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)"
    ]
  }
}
